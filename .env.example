# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores reais
# USO COM DOCKER: docker compose up --build
# ─────────────────────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria
FLASK_ENV=production

# PostgreSQL (usado pelo docker-compose para criar o container e pelo Flask)
POSTGRES_PASSWORD=troque-esta-senha-segura-2026
# A DATABASE_URL é montada automaticamente pelo docker-compose com a senha acima
# Mas pode sobrescrever aqui se precisar:
# DATABASE_URL=postgresql://psdb_user:troque-esta-senha-segura-2026@db:5432/psdb_jundiai

# Chave Fernet para criptografia do CPF
# Gere com: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=cole-aqui-a-chave-fernet-gerada

# E-mail (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app-google

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://seu-servidor-evolution:8080
EVOLUTION_API_KEY=sua-api-key-evolution
EVOLUTION_INSTANCE=psdb
